{
  "name": "user-auth-api",
  "version": "1.0.0",
  "description": "RESTful API for user registration and authentication",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup:mysql": "node setup-mysql.js",
    "test": "node node_modules/cross-env/src/bin/cross-env.js NODE_ENV=test jest --runInBand --coverage",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand --testPathPattern=tests/unit/.*\\.test\\.js$",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration",
    "test:system": "cross-env NODE_ENV=test jest tests/system"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.0",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.6.4",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
